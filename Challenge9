function buildJsBasicsRunLabel(suiteName, environment, buildNumber) {
  const cleanSuite = suiteName.trim();
  const cleanEnv = environment.toLowerCase();
  const cleanBuild = `build-${buildNumber}`;

  return `${cleanSuite} | ${cleanEnv} | ${cleanBuild}`;
}

