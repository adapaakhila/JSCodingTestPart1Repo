function summarizeTestResults(results) {
  const summary = { total: results.length, passed: 0, failed: 0, skipped: 0 };

  for (const label of results) {
    const lower = label.toLowerCase();
    if (lower.includes("pass")) summary.passed++;
    if (lower.includes("fail")) summary.failed++;
    if (lower.includes("skip")) summary.skipped++;
  }

  return summary;
}

// Example usage:
const results = ["Test Pass", "FAIL: bug", "skip step", "Passed validation"];
console.log(summarizeTestResults(results));
// Output: { total: 4, passed: 2, failed: 1, skipped: 1 }
